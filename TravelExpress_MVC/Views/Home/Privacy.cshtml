@{
    ViewData["Title"] = "Privacy Policy";
}
<h1>@ViewData["Title"]</h1>

<p>
    TravelExpress respects your privacy. This application is built for learning and demonstration purposes.
</p>

<h4>Information We Collect</h4>
<ul>
    <li>Basic account information such as name and email during registration</li>
    <li>Booking and payment-related information for reservation tracking</li>
</ul>

<h4>How We Use Your Information</h4>
<ul>
    <li>To authenticate users</li>
    <li>To manage hotel bookings and payments</li>
    <li>To improve application functionality</li>
</ul>

<h4>Data Security</h4>
<p>
    All user data is securely stored in a database and is not shared with third parties.
</p>

<h4>Contact</h4>
<p>
    If you have any questions about this Privacy Policy, please contact the administrator.
</p>
